# Notifications Service environment template
# Env var names follow the pattern: NOTIFICATIONS_{STRUCT_FIELD}_{TAG}
# where STRUCT_FIELD is the Go struct field name (e.g. HTTP, POSTGRES, REDIS, EVENTS, SECURITY)

NOTIFICATIONS_APP_NAME=notifications-app
NOTIFICATIONS_APP_ENV=development
NOTIFICATIONS_APP_VERSION=0.1.0

NOTIFICATIONS_HTTP_HOST=0.0.0.0
NOTIFICATIONS_HTTP_PORT=4000
NOTIFICATIONS_HTTP_READ_TIMEOUT=15s
NOTIFICATIONS_HTTP_WRITE_TIMEOUT=15s
NOTIFICATIONS_HTTP_IDLE_TIMEOUT=60s
# TLS configuration for HTTPS (mkcert certificates) - local development only
# Uncomment and set paths to enable HTTPS
NOTIFICATIONS_HTTP_TLS_CERT_FILE=./config/certs/notifications.codevertex.local.pem
NOTIFICATIONS_HTTP_TLS_KEY_FILE=./config/certs/notifications.codevertex.local-key.pem
NOTIFICATIONS_HTTP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

NOTIFICATIONS_POSTGRES_URL=postgres://postgres:postgres@localhost:5432/notifications?sslmode=disable
NOTIFICATIONS_POSTGRES_MAX_OPEN_CONNS=20
NOTIFICATIONS_POSTGRES_MAX_IDLE_CONNS=10
NOTIFICATIONS_POSTGRES_CONN_MAX_LIFETIME=30m

NOTIFICATIONS_REDIS_ADDR=localhost:6379
NOTIFICATIONS_REDIS_PASSWORD=
NOTIFICATIONS_REDIS_DB=0
NOTIFICATIONS_REDIS_DIAL_TIMEOUT=5s

NOTIFICATIONS_EVENTS_BUS=nats
NOTIFICATIONS_EVENTS_NATS_URL=nats://localhost:4222
NOTIFICATIONS_EVENTS_NATS_STREAM=notifications
NOTIFICATIONS_EVENTS_NATS_SUBJECT=notifications.events
NOTIFICATIONS_EVENTS_NATS_ACK_WAIT=30s

NOTIFICATIONS_PROVIDERS_SENDGRID_API_KEY=
NOTIFICATIONS_PROVIDERS_MAILGUN_DOMAIN=
NOTIFICATIONS_PROVIDERS_MAILGUN_API_KEY=
NOTIFICATIONS_PROVIDERS_TWILIO_ACCOUNT_SID=
NOTIFICATIONS_PROVIDERS_TWILIO_AUTH_TOKEN=
NOTIFICATIONS_PROVIDERS_AFRICAS_TALKING_KEY=
NOTIFICATIONS_PROVIDERS_AFRICAS_TALKING_USERNAME=
NOTIFICATIONS_PROVIDERS_VONAGE_API_KEY=
NOTIFICATIONS_PROVIDERS_VONAGE_API_SECRET=
NOTIFICATIONS_PROVIDERS_PLIVO_AUTH_ID=
NOTIFICATIONS_PROVIDERS_PLIVO_AUTH_TOKEN=
NOTIFICATIONS_PROVIDERS_SMTP_HOST=localhost
NOTIFICATIONS_PROVIDERS_SMTP_PORT=1025
NOTIFICATIONS_PROVIDERS_SMTP_USERNAME=
NOTIFICATIONS_PROVIDERS_SMTP_PASSWORD=
NOTIFICATIONS_PROVIDERS_SMTP_FROM=no-reply@codevertexitsolutions.com
NOTIFICATIONS_PROVIDERS_SMTP_STARTTLS=false
NOTIFICATIONS_PROVIDERS_FCM_SERVICE_ACCOUNT=
NOTIFICATIONS_PROVIDERS_APNS_CERT=
NOTIFICATIONS_PROVIDERS_APNS_KEY=
NOTIFICATIONS_PROVIDERS_DEFAULT_EMAIL_SENDER=CodeVertex <hello@codevertexitsolutions.com>
NOTIFICATIONS_PROVIDERS_DEFAULT_SMS_SENDER=CodeVertex
NOTIFICATIONS_PROVIDERS_DEFAULT_PUSH_TOPIC=general

NOTIFICATIONS_TEMPLATES_DIRECTORY=./templates
NOTIFICATIONS_TEMPLATES_CACHE_TTL=5m

# Optional shared API key for protecting /v1 endpoints
NOTIFICATIONS_SECURITY_API_KEY=

# Auth Service SSO (JWT) settings
NOTIFICATIONS_SECURITY_REQUIRE_JWT=true
NOTIFICATIONS_SECURITY_JWKS_URL=https://sso.codevertexitsolutions.com/api/v1/.well-known/jwks.json
NOTIFICATIONS_SECURITY_JWT_ISSUER=https://sso.codevertexitsolutions.com
NOTIFICATIONS_SECURITY_JWT_AUDIENCE=codevertex

# API key validation database URL (optional, enables API key authentication)
# Set to auth-service database URL to enable API key validation
# NOTIFICATIONS_SECURITY_API_KEY_DB_URL=postgres://postgres:postgres@localhost:5432/auth?sslmode=disable

# Enable background worker process (default: false, worker runs separately)
# NOTIFICATIONS_ENABLE_WORKER=true
