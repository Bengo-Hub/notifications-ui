# Notifications Service environment template
NOTIFICATIONS_APP_NAME=notifications-app
NOTIFICATIONS_APP_ENV=development
NOTIFICATIONS_APP_VERSION=0.1.0

NOTIFICATIONS_HTTP_HOST=0.0.0.0
NOTIFICATIONS_HTTP_PORT=4002
NOTIFICATIONS_HTTP_READ_TIMEOUT=15s
NOTIFICATIONS_HTTP_WRITE_TIMEOUT=15s
NOTIFICATIONS_HTTP_IDLE_TIMEOUT=60s
# TLS configuration for HTTPS (mkcert certificates) - local development only
# Uncomment and set paths to enable HTTPS
NOTIFICATIONS_HTTP_TLS_CERT_FILE=./config/certs/notifications.codevertex.local.pem
NOTIFICATIONS_HTTP_TLS_KEY_FILE=./config/certs/notifications.codevertex.local-key.pem

NOTIFICATIONS_POSTGRES_URL=postgres://postgres:postgres@localhost:5432/notifications?sslmode=disable
NOTIFICATIONS_POSTGRES_MAX_OPEN_CONNS=20
NOTIFICATIONS_POSTGRES_MAX_IDLE_CONNS=10
NOTIFICATIONS_POSTGRES_CONN_MAX_LIFETIME=30m

NOTIFICATIONS_REDIS_ADDR=localhost:6381
NOTIFICATIONS_REDIS_PASSWORD=
NOTIFICATIONS_REDIS_DB=0
NOTIFICATIONS_REDIS_DIAL_TIMEOUT=5s

NOTIFICATIONS_EVENT_BUS=nats
NOTIFICATIONS_NATS_URL=nats://localhost:4222
NOTIFICATIONS_NATS_STREAM=notifications
NOTIFICATIONS_NATS_SUBJECT=notifications.events
NOTIFICATIONS_NATS_ACK_WAIT=30s

NOTIFICATIONS_SENDGRID_API_KEY=
NOTIFICATIONS_MAILGUN_DOMAIN=
NOTIFICATIONS_MAILGUN_API_KEY=
NOTIFICATIONS_TWILIO_ACCOUNT_SID=
NOTIFICATIONS_TWILIO_AUTH_TOKEN=
NOTIFICATIONS_AFRICAS_TALKING_KEY=
NOTIFICATIONS_AFRICAS_TALKING_USERNAME=
NOTIFICATIONS_VONAGE_API_KEY=
NOTIFICATIONS_VONAGE_API_SECRET=
NOTIFICATIONS_PLIVO_AUTH_ID=
NOTIFICATIONS_PLIVO_AUTH_TOKEN=
NOTIFICATIONS_SMTP_HOST=localhost
NOTIFICATIONS_SMTP_PORT=1025
NOTIFICATIONS_SMTP_USERNAME=
NOTIFICATIONS_SMTP_PASSWORD=
NOTIFICATIONS_SMTP_FROM=no-reply@codevertexitsolutions.com
NOTIFICATIONS_SMTP_STARTTLS=false
NOTIFICATIONS_FCM_SERVICE_ACCOUNT=
NOTIFICATIONS_APNS_CERT=
NOTIFICATIONS_APNS_KEY=
NOTIFICATIONS_DEFAULT_EMAIL_SENDER=CodeVertex <hello@codevertexitsolutions.com>
NOTIFICATIONS_DEFAULT_SMS_SENDER=CodeVertex
NOTIFICATIONS_DEFAULT_PUSH_TOPIC=general

NOTIFICATIONS_TEMPLATE_DIRECTORY=./templates
NOTIFICATIONS_TEMPLATE_CACHE_TTL=5m

# Optional shared API key for protecting /v1 endpoints
NOTIFICATIONS_API_KEY=

# Auth Service SSO (JWT) settings
NOTIFICATIONS_REQUIRE_JWT=true
NOTIFICATIONS_JWKS_URL=https://auth.codevertex.local:4101/api/v1/.well-known/jwks.json
NOTIFICATIONS_JWT_ISSUER=https://auth.codevertex.local:4101
NOTIFICATIONS_JWT_AUDIENCE=codevertex

# API key validation database URL (optional, enables API key authentication)
# Set to auth-service database URL to enable API key validation
# NOTIFICATIONS_API_KEY_DB_URL=postgres://postgres:postgres@localhost:5432/auth?sslmode=disable

# Enable background worker process (default: false, worker runs separately)
# NOTIFICATIONS_ENABLE_WORKER=true
